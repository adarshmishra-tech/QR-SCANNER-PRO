{
  "expo": {
    "name": "QRScannerPro",
    "slug": "QRScannerPro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.universal.qrscannerpro",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow QRScannerPro to use the camera to scan codes.",
        "NSPhotoLibraryAddUsageDescription": "Allow QRScannerPro to save generated QR codes to your Photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.universal.qrscannerpro",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow QRScannerPro to access your camera to scan codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow QRScannerPro to access your photos to scan saved QR images."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow QRScannerPro to access your photos.",
          "savePhotosPermission": "Allow QRScannerPro to save QR codes to your gallery."
        }
      ],
      "expo-secure-store"
    ]
  }
}